**/*.xcodeproj/xcuserdata/
**/DerivedData/

# Python
**/__pycache__/
**/*.py[cod]
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/

# Database dumps and local backups
studynest_be/backups/
studynest_be/backup_*.sql

# Logs and local runtime files
**/*.log
**/logs/
**/.DS_Store
**/Thumbs.db

